# Copy to .env and fill in. Do NOT commit .env.
# Supabase publishable (anon) key + URL are browser-safe; the service-role key
# and LOVABLE_API_KEY are server-only secrets — keep them out of VITE_ vars.

SUPABASE_PROJECT_ID=your-project-id
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Exposed to the browser bundle (build-time). Same anon key — never put secrets here.
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Server-only: n8n webhook the app pings to start OM processing.
# If unset, the app still runs but deals stay "pending" until the pipeline is wired.
N8N_WEBHOOK_URL=https://your-n8n-host/webhook/ledger-analyze
N8N_WEBHOOK_SECRET=choose-a-long-random-shared-secret
