# Copy to n8n/.env (gitignored) and fill in. NEVER commit real values or paste them anywhere public.
# docker compose reads this file automatically for ${VAR} substitution.

# A long random shared secret. Generate one with:  openssl rand -hex 32
# Put this SAME value in the APP's env as N8N_WEBHOOK_SECRET.
N8N_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# Supabase project (URL is not secret).
SUPABASE_URL=https://smbjgyvkycfzizuwirrx.supabase.co

# New Supabase SECRET key (sb_secret_...). Privileged — bypasses RLS. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# OpenRouter API key for the free extraction/report model — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxx
